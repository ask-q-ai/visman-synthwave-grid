{
  "pulse": {
    "bpm": 120,
    "beatsPerBar": 4
  },
  "effects": {
    "shader": "crt"
  },
  "canvasLayer": [
    {
      "id": "bg",
      "context": "canvas",
      "type": "rectangle",
      "position": {
        "x": 0,
        "y": 0
      },
      "size": {
        "width": 640,
        "height": 360
      },
      "style": {
        "fillStyle": "#0a0a1a",
        "strokeStyle": "rgba(0,0,0,0)",
        "lineWidth": 0
      }
    },
    {
      "id": "sun-outer",
      "context": "canvas",
      "type": "circle",
      "position": {
        "x": 320,
        "y": 110
      },
      "size": {
        "radius": 70
      },
      "style": {
        "fillStyle": "#CC2200",
        "strokeStyle": "rgba(0,0,0,0)",
        "lineWidth": 0
      }
    },
    {
      "id": "sun-mid",
      "context": "canvas",
      "type": "circle",
      "position": {
        "x": 320,
        "y": 110
      },
      "size": {
        "radius": 50
      },
      "style": {
        "fillStyle": "#FF6600",
        "strokeStyle": "rgba(0,0,0,0)",
        "lineWidth": 0
      }
    },
    {
      "id": "sun-core",
      "context": "canvas",
      "type": "circle",
      "position": {
        "x": 320,
        "y": 110
      },
      "size": {
        "radius": 30
      },
      "style": {
        "fillStyle": "#FFAA00",
        "strokeStyle": "rgba(0,0,0,0)",
        "lineWidth": 0
      }
    },
    {
      "id": "sky-cover",
      "context": "canvas",
      "type": "rectangle",
      "position": {
        "x": 0,
        "y": 0
      },
      "size": {
        "width": 640,
        "height": 110
      },
      "style": {
        "fillStyle": "#0a0a1a",
        "strokeStyle": "rgba(0,0,0,0)",
        "lineWidth": 0
      }
    },
    {
      "id": "horizon",
      "context": "canvas",
      "type": "line",
      "position": {
        "x": 0,
        "y": 110
      },
      "properties": {
        "x2": 640,
        "y2": 110
      },
      "style": {
        "strokeStyle": "#FF00FF",
        "lineWidth": 2
      }
    },
    {
      "id": "h-bar-{i}",
      "repeat": {
        "count": 24
      },
      "context": "canvas",
      "type": "rectangle",
      "position": {
        "x": 0,
        "y": "{{ 112 + i * 10.4 }}"
      },
      "size": {
        "width": 640,
        "height": 1.5
      },
      "style": {
        "fillStyle": "#FF00FF",
        "strokeStyle": "rgba(0,0,0,0)",
        "lineWidth": 0
      },
      "physics": {
        "kinematic": true,
        "bodyType": "kinematic",
        "vy": 55,
        "wrapEdges": true,
        "bounds": {
          "minY": 110,
          "maxY": 370
        }
      }
    },
    {
      "id": "v-line-{i}",
      "repeat": {
        "count": 15
      },
      "context": "canvas",
      "type": "line",
      "position": {
        "x": "{{ 320 + (i - 7) * 40 }}",
        "y": 360
      },
      "properties": {
        "x2": 320,
        "y2": 110
      },
      "style": {
        "strokeStyle": "#00FFFF",
        "lineWidth": 1.5
      }
    }
  ],
  "domLayer": [
    {
      "id": "title",
      "context": "dom",
      "type": "div",
      "position": {
        "x": 220,
        "y": 8
      },
      "properties": {
        "text": "SYNTHWAVE GRID"
      },
      "style": {
        "color": "#FF00FF",
        "fontSize": 24,
        "fontWeight": "bold",
        "fontFamily": "monospace"
      }
    },
    {
      "id": "beat-info",
      "context": "dom",
      "type": "div",
      "position": {
        "x": 195,
        "y": 340
      },
      "properties": {
        "text": "BPM {{ @vm.pulse.bpm }}  ·  BEAT {{ @vm.pulse.beatCount }}  ·  BAR {{ @vm.pulse.barCount }}"
      },
      "style": {
        "color": "#00FFFF",
        "fontSize": 11,
        "fontFamily": "monospace"
      }
    }
  ]
}
